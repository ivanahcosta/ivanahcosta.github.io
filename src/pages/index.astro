---
import "../styles/global.css";

import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import avatar from "../assets/avatar.jpg";
import { Icon } from "astro-icon/components";


import education from "../data/education.js";
import experience from "../data/experience.js";

import { getCollection } from "astro:content";
const works = await getCollection("works");
works.sort((a: any, b: any) => b.data.date - a.data.date);
const recentWorks = works.slice(0, 5);

const brandsImages = Object.values(
  import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/brands/*.{png,jpg,jpeg}",
    {
      eager: true,
    },
  ),
);
---

<Layout>
  <header class="pt-10">
    <div class="container grid gap-5 md:flex justify-between items-center">
			<div class="flex gap-5 items-center">
				<Image src={avatar} alt="Ivana Costa" fetchpriority="high" class="w-14 h-14 rounded-2xl" height={72} width={72} quality={100} format="webp" />
				<div>
					<h1>Ivana Costa</h1>
					<h2 class="text-white/50">
						Desenvolvedora Full Stack / <br>Software Engineer
					</h2>
				</div>
			</div>
			<div class="flex gap-3 items-center">
				<div class="flex items-center gap-3 text-[1.2em]">
          <a href="https://www.linkedin.com/in/ivanahcosta/" target="_blank"><Icon name="linkedin" /></a>
          <a href="https://github.com/ivanahcosta" target="_blank"><Icon name="github" /></a>
          <a href="https://x.com/ivanahcosta" target="_blank"><Icon name="x" /></a>
        </div>
			</div>
		</div>
  </header>
  <main>
    <section id="hero">
      <div class="container">
        <p class="text-[1.9em] leading-[1.2em]">
          Desenvolvendo aplicações escaláveis, performáticas e orientadas à experiência do usuário há mais de 8 anos.
        </p>
      </div>
			<div class="container flex items-center gap-5 pt-5">
				<a href="#projects" class="bg-white text-black rounded-md p-3">Ver projetos selecionados</a>
				<p class="flex gap-3 items-center">
          <span class="w-3 h-3 rounded-md bg-green-500 animate-pulse"></span>
          <span>Disponivel para projetos freelance</span>
        </p>
			</div>
    </section>
    <section id="experience">
      <div class="container">
        <h3 class="text-white/50 tracking-wide uppercase text-[0.7em]">Experiência</h3>
        <div class="grid divide-y divide-white/10">
					{
            experience.map((item: any, index: number) => {
              return (
                <div class="py-3 flex justify-between leading-[1.3em]">
                  <div>
										<h4>{item.position}</h4>
										<p class="text-white/50">{item.company}</p>
									</div>
                  <p class="text-[0.8em] text-white/50 w-25 text-right">{item.time}</p>
                </div>
              );
            })
          }
        </div>
        <a href="https://www.linkedin.com/in/ivanahcosta/" target="_blank" class="bg-white/10 p-3 justify-center rounded-md flex items-center gap-2">
          <span>Veja todas as minhas experiências</span>
          <Icon name="arrow-up-right" /></a>
        </a>
      </div>
    </section>
    <section id="projects">
      <div class="container">
        <h3 class="text-white/50 tracking-wide uppercase text-[0.7em]">Projetos selecionados</h3>
        <div class="grid divide-y divide-white/10">
          {
            recentWorks.map((item: any, index: number) => {
              return (
                <a class="py-3 flex justify-between leading-[1.3em]" href={item.data.link} target="_blank">
                  <div>
                    <div class="flex gap-1 items-center">
                      <Icon name="link" />
                      <h4 class="underline decoration-dotted">{item.data.title}</h4>
                    </div>
                    <p class="text-white/50">{item.data.client}</p>
                  </div>
                  <p class="text-[0.8em] text-white/50 w-25 text-right">{item.data.date.getFullYear().toString()}</p>
                </a>
              );
            })
          }
        </div>
        <a href="/projects" class="bg-white/10 p-3 justify-center rounded-md flex items-center gap-2 opacity-50 pointer-events-none">
          <span>Ver todos os projetos</span>
          <Icon name="lock" /></a>
        </a>
      </div>
    </section>
    <section id="about">
      <div class="container">
        <h3 class="text-white/50 tracking-wide uppercase text-[0.7em]">Sobre</h3>
        <p class="py-5 leading-[1.3em]">
          Desenvolvedora com mais de 8 anos de experiência construindo aplicações web que equilibram performance, escalabilidade e uma boa experiência para quem usa. Minha trajetória passou por e-commerces de grande porte, plataformas financeiras e projetos com diferentes níveis de complexidade, sempre com um olhar atento para arquitetura front-end, organização de código e qualidade técnica.
          <br><br>
          Gosto de trabalhar próxima do problema, entendendo o contexto antes de sair implementando soluções. Ao longo dos anos, acabei me envolvendo não só com desenvolvimento, mas também com decisões de arquitetura, design systems e melhorias contínuas de performance. Fora do código, sou movida por curiosidade e gosto de explorar outras formas de expressão, como fotografia e desenho — coisas que, de alguma forma, também influenciam meu jeito de construir interfaces.
        </p>
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <h4 class="text-white/90 tracking-wide uppercase text-[0.7em]">Skills</h4>
            <ul class="inline-flex flex-wrap gap-2 pt-5">
              <li class="bg-white/10 p-2 rounded-md">React</li>
              <li class="bg-white/10 p-2 rounded-md">TypeScript</li>
              <li class="bg-white/10 p-2 rounded-md">JavaScript</li>
              <li class="bg-white/10 p-2 rounded-md">VTEX IO</li>
              <li class="bg-white/10 p-2 rounded-md">Node.js</li>
              <li class="bg-white/10 p-2 rounded-md">HTML & CSS</li>
              <li class="bg-white/10 p-2 rounded-md">Design Systems</li>
              <li class="bg-white/10 p-2 rounded-md">Performance Web</li>
              <li class="bg-white/10 p-2 rounded-md">APIs REST</li>
              <li class="bg-white/10 p-2 rounded-md">CI/CD</li>
            </ul>
          </div>
          <div>
            <!-- <h4>Hobbies</h4>
            <ul class="pt-5 grid gap-2">
              <li>
                Artes marciais (kickboxing, jiu-jitsu e boxe)
              </li>
              <li>Fotografia</li>
              <li>Desenho digital</li>
            </ul> -->

            <!-- <div class="img-bg">
              <img src="https://photos.fife.usercontent.google.com/pw/AP1GczMpf8Wz1sqgl9-87tfPNc6zY9cm46zi5KHR-0snBkmZCDdC0N_US_Wt1Q=w709-h945-s-no-gm" alt="" class="img-box box-1"> 
              <img src="https://photos.fife.usercontent.google.com/pw/AP1GczN6QVvQqjOgp29aGYraUcoO-U2nRg97g6CWQUnAN22Vb46zwpsvIqCfrg=w532-h945-s-no-gm" alt="" class="img-box box-2"> 
              <img src="https://photos.fife.usercontent.google.com/pw/AP1GczN0rodVvZ_ibhSqb5m__0nvb-KSqgQmdwVKLlDAqFy1jBcTTTLo5Ky8oA=w532-h945-s-no-gm" alt="" class="img-box box-3"> 
            </div> -->
          </div>
        </div>
      </div>
    </section>
    <section id="education">
      <div class="container">
        <h3 class="text-white/50 tracking-wide uppercase text-[0.7em]">Educação & Certificados</h3>
        <div class="grid divide-y divide-white/10">
					{
            education.map((item: any, index: number) => {
              return (
                <div class="py-3 flex justify-between leading-[1.3em]">
                  <div>
										<h4>{item.course}</h4>
										<p class="text-white/50">{item.school}</p>
									</div>
                  <p class="text-[0.8em] text-white/50 w-25 text-right">{item.time}</p>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>
	<footer class="pb-10">
		<div class="container flex justify-between items-center">
			<p>©2026 Ivana Costa</p> 
			<a href="#hero">Voltar ao topo</a>
		</div>
	</footer>
</Layout>

<script>

  
</script>
